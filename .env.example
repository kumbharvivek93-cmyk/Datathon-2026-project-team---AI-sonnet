# Local development defaults. Copy this file to .env and replace credentials.
FLASK_CONFIG=development
FLASK_DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:///crime_intelligence.db
AUTO_CREATE_DB=true
SEED_DEMO_ADMIN=true
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_EMAIL=admin@ksp.local
DEMO_ADMIN_PASSWORD=ChangeMe123!
DEMO_ADMIN_NAME=Platform Administrator
SESSION_COOKIE_SECURE=false
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
